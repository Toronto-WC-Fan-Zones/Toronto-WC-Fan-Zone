# Copy this file to .env.local and fill in real values.
# .env.local is gitignored - npm run ingest / npm run promote load it
# automatically (via --env-file-if-exists), nothing else to configure.

# https://www.football-data.org/client/register (free, email signup)
FOOTBALL_DATA_API_KEY=

# https://developer.ticketmaster.com (free, "Consumer Key")
TICKETMASTER_API_KEY=

# https://www.eventbrite.com/platform/api-keys (free OAuth token)
EVENTBRITE_TOKEN=
# Comma-separated Eventbrite organizer ids to track - the public search API
# was removed, so this connector only works for known organizers.
EVENTBRITE_ORGANIZER_IDS=

# https://www.reddit.com/prefs/apps - create a "script" type app for
# client_id + client_secret
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Optional, comma-separated, defaults to "toronto"
REDDIT_SUBREDDITS=
